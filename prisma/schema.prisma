// =============================================================================
// LegitBites Cashflow Management — Prisma Schema
// =============================================================================
// Defines the core data model for the cashflow management application.
// Uses PostgreSQL (via Supabase) as the underlying database.
//
// RBAC Strategy:
// - `Role` enum with three values: OWNER, STAFF, and ADMIN
// - OWNER: Full access — reports, master data, and transaction management
// - STAFF: Limited access — can only create daily transactions
// - ADMIN: Super-user — manage users, categories, system settings, view audit logs
//
// The `User.id` field is a UUID that maps 1:1 with the Supabase Auth user ID,
// allowing us to sync authentication state with our application data.
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

// Connection URLs are configured in prisma.config.ts (Prisma 7+).
// Only the provider is declared here.
datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

/// Role-Based Access Control — determines what a user can do in the app.
/// OWNER: Full access (reports, master data, categories, all transactions).
/// STAFF: Restricted to recording daily cash-in / cash-out transactions.
/// ADMIN: Super-user — manages users, categories, system settings, and audit logs.
///        ADMIN routes are completely isolated from OWNER and STAFF dashboards.
enum Role {
  OWNER
  STAFF
  ADMIN
}

/// Transaction type — classifies a financial record as money coming in or out.
/// INCOME: Revenue / cash-in (e.g., daily food sales).
/// EXPENSE: Cost / cash-out (e.g., raw material purchase).
enum TransactionType {
  INCOME
  EXPENSE
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

/// Represents an application user, linked to a Supabase Auth account.
/// The `id` field is a UUID that MUST match the Supabase Auth user's `id`
/// so we can look up app-level data from the authenticated session.
model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String
  role      Role     @default(STAFF)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // --- Relations ---
  transactions Transaction[]
  auditLogs    AuditLog[]

  @@map("users")
}

/// Master data for income/expense categories.
/// Examples: "Penjualan Harian", "Bahan Baku", "Gaji Karyawan", "Listrik & Air".
/// ADMIN manages categories through the Admin Panel.
/// `isActive` controls whether the category is available for new transactions.
model Category {
  id        String          @id @default(uuid()) @db.Uuid
  name      String          @unique
  type      TransactionType
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  deletedAt DateTime?       @map("deleted_at")

  // --- Relations ---
  transactions Transaction[]

  @@index([deletedAt])
  @@index([isActive])
  @@map("categories")
}

/// A single cashflow transaction (income or expense).
/// Each transaction is recorded by a user (STAFF or OWNER) and categorized.
///
/// Key design decisions:
/// - `amount` uses `Decimal` for precise financial calculations (avoids
///   floating-point rounding errors that plague standard Float/Double types).
/// - `date` is the business date of the transaction, which may differ from
///   `createdAt` (the timestamp when the record was actually created).
/// - `description` is optional, allowing quick entry without friction.
model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  amount      Decimal         @db.Decimal(15, 2)
  type        TransactionType
  date        DateTime        @db.Date
  description String?
  imageUrl    String?
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  // --- Relations ---
  /// The category this transaction belongs to.
  categoryId String   @map("category_id") @db.Uuid
  category   Category @relation(fields: [categoryId], references: [id])

  /// The user who recorded this transaction.
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  @@index([date])
  @@index([type])
  @@index([categoryId])
  @@index([userId])
  @@index([deletedAt])
  @@map("transactions")
}

/// Audit log — records important system-level actions performed by ADMIN or users.
/// Used for accountability tracking in the Admin Panel (/admin/logs).
///
/// `action`: short action identifier (e.g., "USER_CREATED", "ROLE_CHANGED")
/// `details`: optional JSON string with additional context (e.g., target user, old/new values)
model AuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  action    String
  details   String?
  createdAt DateTime @default(now()) @map("created_at")

  // --- Relations ---
  /// The user who performed this action.
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

/// System-level key-value settings managed by ADMIN.
/// Current keys:
/// - "MAINTENANCE_MODE": "true" | "false" — controls site-wide maintenance redirect
///
/// Using a string value for `value` to support multiple types (bool, number, JSON)
/// without needing schema changes for each new setting.
model SystemSetting {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique
  value String

  @@map("system_settings")
}
